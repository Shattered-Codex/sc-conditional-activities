<section class="tab activity-{{ tab.id }} {{ tab.cssClass }} sc-ca-condition-tab" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  <fieldset>
    <legend>{{ strings.heading }}</legend>
    <p class="hint">{{ strings.hint }}</p>
    <p class="hint">{{ strings.variables }}</p>
    <a class="sc-ca-help-link" href="{{ conditionWikiUrl }}" target="_blank" rel="noopener">
      <i class="fas fa-up-right-from-square"></i> {{ strings.wiki }}
    </a>

    {{#if conditionInvalid}}
    <p class="notification warning sc-ca-validation-warning">
      <i class="fas fa-triangle-exclamation"></i>
      {{ strings.invalid }} {{ validationMessage }}
    </p>
    {{/if}}

    {{#if editable}}
    <code-mirror
      name="{{ conditionFlagPath }}"
      language="javascript"
      indent="2"
      class="sc-ca-condition-code"
      aria-label="{{ strings.label }}"
    >{{ condition }}</code-mirror>
    {{else}}
    <textarea
      name="{{ conditionFlagPath }}"
      class="sc-ca-condition-code sc-ca-condition-code--readonly"
      rows="10"
      placeholder="{{ strings.placeholder }}"
      disabled>{{ condition }}</textarea>
    {{/if}}

    <div class="sc-ca-form-field">
      <label class="sc-ca-field-label" for="{{ warningInputId }}">
        <span>{{ strings.warningLabel }}</span>
        <i class="fa-solid fa-circle-info" data-tooltip="{{ strings.warningTooltip }}"></i>
      </label>
      <p class="hint">{{ strings.warningHint }}</p>
      <textarea
        id="{{ warningInputId }}"
        name="{{ warningMessageFlagPath }}"
        class="sc-ca-warning-message"
        rows="4"
        placeholder="{{ strings.warningPlaceholder }}"
        data-sc-ca-warning-input
        {{#unless editable}}disabled{{/unless}}
      >{{ warningMessage }}</textarea>
    </div>

    <div class="sc-ca-form-field">
      <label class="sc-ca-checkbox-field" for="{{ disableWarningInputId }}">
        <input
          id="{{ disableWarningInputId }}"
          type="checkbox"
          name="{{ disableWarningMessageFlagPath }}"
          {{#if disableWarningMessage}}checked{{/if}}
          {{#unless editable}}disabled{{/unless}}
        >
        <span>{{ strings.disableWarningLabel }}</span>
        <i class="fa-solid fa-circle-info" data-tooltip="{{ strings.disableWarningTooltip }}"></i>
      </label>
      <p class="hint">{{ strings.disableWarningHint }}</p>
    </div>

    <div class="sc-ca-form-field">
      <label class="sc-ca-field-label" for="{{ badgeInputId }}">
        <span>{{ strings.badgeLabel }}</span>
        <i class="fa-solid fa-circle-info" data-tooltip="{{ strings.badgeTooltip }}"></i>
      </label>
      <div class="sc-ca-inline-meta">
        <p class="hint">{{ strings.badgeHint }}</p>
        <span class="sc-ca-char-counter"><span data-sc-ca-badge-counter>{{ badgeLabelLength }}/{{ badgeLabelMaxLength }}</span> {{ strings.charactersUsed }}</span>
      </div>
      <input
        id="{{ badgeInputId }}"
        type="text"
        name="{{ badgeLabelFlagPath }}"
        class="sc-ca-badge-label-input"
        value="{{ badgeLabel }}"
        maxlength="{{ badgeLabelMaxLength }}"
        placeholder="{{ strings.badgePlaceholder }}"
        data-sc-ca-badge-input
        {{#unless editable}}disabled{{/unless}}
      >
    </div>

    <div class="sc-ca-preview" aria-live="polite">
      <p class="sc-ca-preview-title">{{ strings.preview }}</p>
      <div class="sc-ca-preview-row">
        <span class="sc-ca-preview-label">{{ strings.previewBadge }}</span>
        <span class="sc-ca-locked-label" data-sc-ca-preview-badge>{{ previewBadgeLabel }}</span>
      </div>
      <div class="sc-ca-preview-row sc-ca-preview-row--stacked">
        <span class="sc-ca-preview-label">{{ strings.previewWarning }}</span>
        <p class="notification warning sc-ca-preview-warning" data-sc-ca-preview-warning>
          <i class="fas fa-triangle-exclamation"></i>
          {{ previewWarningMessage }}
        </p>
      </div>
    </div>
  </fieldset>
</section>
